# Node.js / JavaScript project .gitignore
# Dependency directories
node_modules/
.pnpm-store/

# Environment variables
.env

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
debug.log

# Build output
dist/
build/

# OS generated files
.DS_Store
Thumbs.db

# IDE / editor folders
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# Docker artifacts
docker-compose.override.yml
Dockerfile
.dockerignore

# Miscellaneous
*.log
